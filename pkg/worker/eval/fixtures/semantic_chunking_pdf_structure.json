{
  "id": "semantic_chunking_pdf_structure",
  "description": "Prefers source file structure when raw text headings are degraded.",
  "stage": "semantic_chunking",
  "input": {
    "filename": "market-map.pdf",
    "raw_text": "MarketMapOverview TAMSAMSOM details.\nRevenue Table 2024 ARR 12M 18M.\nAcquisition Channels paid search partner referrals.",
